{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Quiz App",
      "type": "npm",
      "script": "dev",
      "path": "quiz-app",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "react-router dev",
          "endsPattern": "Local:\\s+http://localhost:5173/"
        }
      }
    }
  ]
}
